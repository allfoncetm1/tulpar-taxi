<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TulparTaxi" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/tulpar_light</item>
        <item name="android:navigationBarColor">@color/tulpar_light</item>
        <item name="android:windowBackground">@color/tulpar_light</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.TulparTaxi.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/splash_background</item>
        <item name="android:windowSplashScreenAnimationDuration">200</item>
        <item name="postSplashScreenTheme">@style/Theme.TulparTaxi</item>
    </style>
</resources>
