# === ЛОКАЛЬНАЯ РАЗРАБОТКА ===
DB_HOST=localhost
DB_PORT=5433
DB_NAME=tulpar_db
DB_USER=tulpar
DB_PASS=tulpar_dev

# === RAILWAY / PRODUCTION ===
# DATABASE_URL даст Railway автоматически когда добавишь Postgres
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# === ОБЩЕЕ ===
JWT_SECRET=change-me-to-long-random-string-min-32-chars
JWT_EXPIRES_IN=30d
SMS_PROVIDER=stub

# Firebase Admin SDK (JSON одной строкой)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

PORT=3000
NODE_ENV=development
